# ============================================================
# Configuration Backend — Botola Pro Inwi
# Projet PFE 2024/2025
# ============================================================
# Copiez ce fichier vers .env et adaptez les valeurs

# --- Serveur ---
PORT=5000
NODE_ENV=development

# --- Base de données MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=botola_pro

# --- JWT (JSON Web Token) ---
JWT_SECRET=botola_pro_pfe_2025_secret_key_change_me
JWT_EXPIRES_IN=24h

# --- CORS ---
CORS_ORIGIN=http://localhost:8090

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
